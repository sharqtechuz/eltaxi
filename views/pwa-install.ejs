<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ElTaksi - O'rnatish</title>
<link rel="manifest" href="/manifest.json">
<style>
body {
  font-family: 'Poppins', sans-serif;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
  background:#070b14;
  color:white;
  flex-direction:column;
  text-align:center;
}
button {
  padding:15px 30px;
  font-size:1rem;
  border:none;
  border-radius:10px;
  background:linear-gradient(135deg,#fbbf24,#f59e0b);
  color:#0f172a;
  font-weight:800;
  cursor:pointer;
  margin-top:20px;
}
</style>
</head>
<body>

<h1>ElTaksi ilovasini o'rnatish</h1>
<p>“Install” tugmasini bosib ilovani telefoningizga o‘rnating</p>

<button id="installBtn">Install</button>

<script>
let deferredPrompt;

window.addEventListener('beforeinstallprompt', (e)=>{
  e.preventDefault();
  deferredPrompt = e;
});

document.getElementById('installBtn').addEventListener('click', async ()=>{
  if(deferredPrompt){
    deferredPrompt.prompt();
    const choice = await deferredPrompt.userChoice;
    console.log(choice.outcome);
    deferredPrompt = null;
  } else {
    alert("Ilova o'rnatish imkoniyati hozircha mavjud emas");
  }
});
</script>

</body>
</html>