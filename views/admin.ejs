<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ElTaksi | Boshqaruv Markazi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg: #030712;
            --glass: rgba(17, 24, 39, 0.7);
            --amber: #fbbf24;
            --amber-glow: rgba(251, 191, 36, 0.2);
            --text: #f3f4f6;
            --text-dim: #9ca3af;
            --sidebar-width: 260px;
            --border: rgba(255, 255, 255, 0.08);
            --green: #10b981;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        
        body { 
            background: var(--bg); 
            background-image: radial-gradient(circle at 50% 50%, #111827 0%, #030712 100%);
            color: var(--text); 
            display: flex; 
            height: 100vh;
            overflow: hidden; 
        }

        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--glass);
            backdrop-filter: blur(15px);
            border-right: 1px solid var(--border);
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            z-index: 10;
        }

        .sidebar h2 { 
            color: var(--amber); 
            font-size: 1.5rem;
            margin-bottom: 40px; 
            letter-spacing: 3px; 
            text-align: center;
            text-shadow: 0 0 15px var(--amber-glow);
        }

        .menu-item {
            padding: 14px 18px;
            margin-bottom: 8px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            color: var(--text-dim);
            font-weight: 500;
            text-decoration: none;
        }

        .menu-item i { margin-right: 12px; width: 20px; text-align: center; }

        .menu-item:hover, .menu-item.active { 
            background: rgba(251, 191, 36, 0.1); 
            color: var(--amber); 
            transform: translateX(5px);
        }

        .main-content {
            flex: 1;
            height: 100vh;
            overflow-y: auto;
            padding: 40px;
        }

        .glass-panel {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 20px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card { padding: 25px; text-align: center; transition: transform 0.3s ease; }
        .stat-card h3 { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; margin-bottom: 10px; }
        .stat-card p { font-size: 1.8rem; font-weight: 800; color: var(--amber); }

        .btn {
            padding: 12px 20px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: 0.3s;
        }

        .btn-amber { background: var(--amber); color: #000; }
        .btn-amber:hover { opacity: 0.9; transform: scale(1.02); }

        .table-container { margin-top: 20px; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 800px; }
        th { background: rgba(255,255,255,0.03); padding: 20px; text-align: left; color: var(--text-dim); font-size: 0.8rem; }
        td { padding: 18px 20px; border-top: 1px solid var(--border); font-size: 0.9rem; }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .online { color: #10b981; background: rgba(16, 185, 129, 0.1); }
        .offline { color: #ef4444; background: rgba(239, 68, 68, 0.1); }

        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            z-index: 1000;
            justify-content: center; align-items: center;
        }

        .modal-content { width: 450px; padding: 35px; position: relative; }
        .modal-content input, .modal-content select, .modal-content textarea {
            width: 100%; padding: 14px; margin-top: 15px;
            background: rgba(0,0,0,0.3); border: 1px solid var(--border);
            color: #fff; border-radius: 12px; outline: none;
        }

        .close-btn { position: absolute; top: 15px; right: 20px; cursor: pointer; color: var(--text-dim); }

        .action-icon {
            width: 35px; height: 35px; border-radius: 8px;
            display: inline-flex; align-items: center; justify-content: center;
            border: 1px solid var(--border); color: var(--text-dim);
            cursor: pointer; margin-right: 5px;
        }
        .action-icon:hover { border-color: var(--amber); color: var(--amber); }

        /* Settings Grid inside Modal */
        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            text-align: left;
            margin-top: 15px;
        }
        .settings-grid label { font-size: 0.75rem; color: var(--text-dim); }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>EL TAKSI</h2>
        <p style="text-align: center; font-size: 0.7rem; color: var(--text-dim); margin-top: -35px; margin-bottom: 30px; letter-spacing: 1px;">
            MARKAZIY BOSHQARUV
        </p>

        <div class="menu-item active"><i class="fas fa-th-large"></i> Dashboard</div>
        <div class="menu-item" onclick="openModal('addDriverModal')"><i class="fas fa-user-plus"></i> Haydovchi Qo'shish</div>
        <div class="menu-item" onclick="openModal('broadcastModal')"><i class="fas fa-bullhorn"></i> Xabarnoma</div>
        <div class="menu-item" onclick="initPinGate()"><i class="fas fa-cogs"></i> Taksometr & Tariflar</div>
        
        <a href="/admin/logout" class="menu-item" style="margin-top: auto; color: #ef4444; text-decoration: none;">
            <i class="fas fa-power-off"></i> Tizimdan Chiqish
        </a>
    </div>

    <div class="main-content">
        <div class="stats-grid">
            <div class="stat-card glass-panel">
                <h3>Jami Mijozlar</h3>
                <p><%= customerCount %></p>
            </div>
            <div class="stat-card glass-panel" style="border-bottom: 2px solid var(--green);">
                <h3>Online Haydovchilar</h3>
                <p id="online-count"><%= onlineCount %></p>
            </div>
            <div class="stat-card glass-panel">
                <h3>Umumiy Tushum</h3>
                <p style="font-size: 1.2rem;"><%= totalStats.total.toLocaleString() %> UZS</p> 
            </div>
            <div class="stat-card glass-panel" style="border-bottom: 2px solid var(--amber);">
                <h3>Jami Safarlar</h3>
                <p><%= totalStats.count %></p>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <div>
                <h2>Haydovchilar Monitoringi</h2>
                <small style="color: var(--text-dim);">Tizim holati: Markazlashgan</small>
            </div>
            <div style="display: flex; gap: 10px;">
                <select id="regionFilter" onchange="filterTable()" style="background: var(--glass); color: white; border: 1px solid var(--border); padding: 10px; border-radius: 10px;">
                    <option value="">Barcha hududlar</option>
                    <option value="Urgut">Urgut</option>
                    <option value="Bulungur">Bulungur</option>
                    <option value="Tayloq">Tayloq</option>
                </select>
                <input type="text" id="driverSearch" placeholder="Ism yoki ID bo'yicha..." onkeyup="filterTable()" 
                       style="background: var(--glass); border: 1px solid var(--border); padding: 10px 15px; border-radius: 10px; color: white; width: 250px;">
            </div>
        </div>

        <div class="table-container glass-panel">
            <table id="driverTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Haydovchi / Hudud</th>
                        <th>Mashina</th>
                        <th>Ballar</th>
                        <th>Bugun (UZS)</th>
                        <th>Holat</th>
                        <th>Amallar</th>
                    </tr>
                </thead>
                <tbody>
                    <% drivers.forEach(driver => { %>
                    <tr data-region="<%= driver.region %>">
                        <td style="color: var(--amber); font-weight: bold;">#<%= driver.driverIdCustom %></td>
                        <td>
                            <b><%= driver.driverName %></b><br>
                            <small style="color: var(--amber);"><%= driver.region %></small>
                        </td>
                        <td><%= driver.carModel %><br><small style="color: var(--text-dim);"><%= driver.carNumber %></small></td>
                        <td><b style="color: var(--amber);">🪙 <%= driver.statistics.balls || 0 %></b></td>
                        <td><b><%= driver.statistics.todayEarned.toLocaleString() %></b></td>
                        <td>
                            <span class="status-badge <%= driver.isOnline ? 'online' : 'offline' %>">
                                <i class="fas fa-circle" style="font-size: 0.5rem;"></i>
                                <%= driver.isOnline ? 'Online' : 'Oflayn' %>
                            </span>
                        </td>
                        <td>
                            <div class="action-icon" onclick="openDirectMessage('<%= driver._id %>', '<%= driver.driverName %>')" title="Xabar yuborish"><i class="fas fa-envelope"></i></div>
                            <div class="action-icon" title="Ball qo'shish" onclick="editBalls('<%= driver._id %>', '<%= driver.statistics.balls %>')"><i class="fas fa-coins"></i></div>
                            <div class="action-icon" title="Sozlash" onclick="location.href='/admin/edit-driver/<%= driver._id %>'"><i class="fas fa-edit"></i></div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="addDriverModal" class="modal">
        <div class="modal-content glass-panel">
            <i class="fas fa-times close-btn" onclick="closeModal('addDriverModal')"></i>
            <h2 style="color: var(--amber);">Yangi Haydovchi Qo'shish</h2>
            <form action="/admin/add-driver" method="POST">
                <input type="text" name="driverName" placeholder="To'liq Ismi" required>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <input type="text" name="login" placeholder="Login" required>
                    <input type="password" name="password" placeholder="Parol" required>
                </div>
                <input type="text" name="carModel" placeholder="Mashina (Masalan: Nexia 3)" required>
                <input type="text" name="carNumber" placeholder="Davlat raqami" required>
                <input type="text" name="phone" placeholder="Telefon (998901234567)" required>
                <select name="region">
                    <option value="Urgut">Urgut</option>
                    <option value="Bulungur">Bulungur</option>
                    <option value="Tayloq">Tayloq</option>
                </select>
                <select name="tariff">
                    <option value="Standart">Standart Tarif</option>
                    <option value="Plus">Plus Tarif</option>
                    <option value="Premium">Premium Tarif</option>
                </select>
                <button type="submit" class="btn btn-amber" style="width: 100%; margin-top: 25px;">Ro'yxatdan O'tkazish</button>
            </form>
        </div>
    </div>

    <div id="broadcastModal" class="modal">
        <div class="modal-content glass-panel">
            <i class="fas fa-times close-btn" onclick="closeModal('broadcastModal')"></i>
            <h2>Markaziy Xabarnoma</h2>
            <select id="targetGroup">
                <option value="all_drivers">Barcha haydovchilarga</option>
                <option value="all_customers">Barcha mijozlarga</option>
            </select>
            <textarea id="broadcastMsg" placeholder="E'lon matnini yozing..." rows="5"></textarea>
            <button onclick="sendBroadcast()" class="btn btn-amber" style="width: 100%; margin-top: 20px;">Yuborish</button>
        </div>
    </div>

    <div id="pinGateModal" class="modal">
        <div class="modal-content glass-panel" style="width: 320px; text-align: center;">
            <i class="fas fa-lock" style="font-size: 2.5rem; color: var(--amber); margin-bottom: 15px;"></i>
            <h3>Xavfsizlik PIN</h3>
            <input type="password" id="pinInput" maxlength="4" placeholder="****" style="text-align: center; font-size: 2rem; letter-spacing: 15px;">
            <button onclick="verifyPin()" class="btn btn-amber" style="width: 100%; margin-top: 20px;">Tasdiqlash</button>
        </div>
    </div>

    <div id="settingsModal" class="modal">
        <div class="modal-content glass-panel" style="width: 500px;">
            <i class="fas fa-times close-btn" onclick="closeModal('settingsModal')"></i>
            <h2 style="color: var(--amber); margin-bottom: 20px;"><i class="fas fa-sliders-h"></i> Tizim Sozlamalari</h2>
            
            <form id="settingsForm">
                <div class="settings-grid">
                    <div>
                        <label>O'tirish (Base Fare)</label>
                        <input type="number" id="base_fare" value="5000">
                    </div>
                    <div>
                        <label>1 km uchun (Standart)</label>
                        <input type="number" id="price_km" value="2000">
                    </div>
                    <div>
                        <label>Minimal masofa (km)</label>
                        <input type="number" id="min_dist" value="2">
                    </div>
                    <div>
                        <label>Kutish (1 minut uchun)</label>
                        <input type="number" id="wait_price" value="500">
                    </div>
                </div>
                
                <div style="margin-top: 20px; text-align: left;">
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text);">
                        <input type="checkbox" id="auto_queue" checked style="width: 20px; height: 20px; margin: 0;"> 
                        Avtomatik navbat tizimini yoqish
                    </label>
                </div>

                <button type="button" onclick="saveSettings()" class="btn btn-amber" style="width: 100%; margin-top: 25px;">SAQLASH VA YANGILASH</button>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        // Filtrlash funksiyasi
        function filterTable() {
            let search = document.getElementById('driverSearch').value.toLowerCase();
            let region = document.getElementById('regionFilter').value;
            let rows = document.querySelectorAll('#driverTable tbody tr');

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                let rowRegion = row.getAttribute('data-region');
                let matchesSearch = text.includes(search);
                let matchesRegion = region === "" || rowRegion === region;
                row.style.display = (matchesSearch && matchesRegion) ? '' : 'none';
            });
        }

        // PIN Gate
        function initPinGate() {
            document.getElementById('pinInput').value = '';
            openModal('pinGateModal');
        }

        function verifyPin() {
            if (document.getElementById('pinInput').value === "7788") {
                closeModal('pinGateModal');
                openModal('settingsModal');
            } else { 
                alert("PIN xato!"); 
                document.getElementById('pinInput').value = '';
            }
        }

        // Sozlamalarni saqlash
        async function saveSettings() {
            const settings = {
                baseFare: document.getElementById('base_fare').value,
                pricePerKm: document.getElementById('price_km').value,
                minDist: document.getElementById('min_dist').value,
                waitPrice: document.getElementById('wait_price').value,
                autoQueue: document.getElementById('auto_queue').checked
            };

            try {
                const res = await fetch('/admin/update-settings', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(settings)
                });
                if(res.ok) {
                    alert("Tariflar yangilandi!");
                    socket.emit('admin_settings_changed', settings);
                    closeModal('settingsModal');
                }
            } catch (err) { alert("Xatolik!"); }
        }

        // Xabarnoma
        async function sendBroadcast() {
            const msg = document.getElementById('broadcastMsg').value;
            if(!msg) return;
            const res = await fetch('/admin/send-message', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ target: document.getElementById('targetGroup').value, message: msg })
            });
            if(res.ok) { alert("Xabar yuborildi!"); closeModal('broadcastModal'); }
        }

        function openDirectMessage(id, name) {
            let msg = prompt(`${name} uchun xabar:`);
            if(msg) {
                fetch('/admin/send-message', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ driverId: id, message: msg })
                });
                alert("Xabar yuborildi");
            }
        }

        function editBalls(id, current) {
            let newVal = prompt("Yangi ball miqdorini kiriting:", current);
            if(newVal !== null) {
                fetch('/admin/update-balls', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ driverId: id, balls: newVal })
                }).then(() => location.reload());
            }
        }

        // Real vaqtda statuslarni yangilash
        socket.on('update_online_count', (data) => {
            document.getElementById('online-count').innerText = data.count;
        });

         window.onclick = (e) => {
    if (e.target.classList.contains('modal')) {
        e.target.style.display = 'none';
    }
}
    </script>
</body>
</html>